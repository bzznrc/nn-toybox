{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.run",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--demo",
        "${input:activeDemo}",
        "--dataset",
        "${input:activeDataset}",
        "--steps",
        "${input:runSteps}"
      ]
    },
    {
      "name": "Display",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.display",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--demo",
        "${input:activeDemo}",
        "--dataset",
        "${input:activeDataset}"
      ]
    },
    {
      "name": "Train Model",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.run",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--demo",
        "${input:trainModelDemo}",
        "--dataset",
        "${input:trainModelDataset}",
        "--steps",
        "${input:trainModelSteps}",
        "--save-every",
        "${input:saveEvery}"
      ]
    },
    {
      "name": "Capture",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.capture_demo",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "NN_TOYBOX_RENDER_VISIBLE": "0"
      },
      "args": [
        "--demo",
        "${input:activeDemo}",
        "--dataset",
        "${input:activeDataset}"
      ]
    }
  ],
  "inputs": [
    {
      "id": "activeDemo",
      "type": "pickString",
      "description": "Demo",
      "default": "grad",
      "options": [
        "grad",
        "embed",
        "encode",
        "diffuse",
        "trace",
        "conv",
        "attend",
        "optim"
      ]
    },
    {
      "id": "trainModelDemo",
      "type": "pickString",
      "description": "Model demo to train headlessly",
      "default": "trace",
      "options": [
        "trace",
        "conv"
      ]
    },
    {
      "id": "activeDataset",
      "type": "pickString",
      "description": "Dataset",
      "default": "Distributions",
      "options": [
        "Distributions",
        "Text - Tiny Semantics",
        "Text - Big Tiny Semantics",
        "Images - Icons",
        "Images - Patterns",
        "Digits - 8x8 Mini",
        "Text - Subject Verb Agreement",
        "Optimization - Loss Landscapes"
      ]
    },
    {
      "id": "trainModelDataset",
      "type": "pickString",
      "description": "Model training dataset",
      "default": "Digits - 8x8 Mini",
      "options": [
        "Digits - 8x8 Mini"
      ]
    },
    {
      "id": "runSteps",
      "type": "promptString",
      "description": "Run steps",
      "default": "1000"
    },
    {
      "id": "trainModelSteps",
      "type": "promptString",
      "description": "Train model steps",
      "default": "1000"
    },
    {
      "id": "saveEvery",
      "type": "promptString",
      "description": "Save every N steps",
      "default": "250"
    }
  ]
}
