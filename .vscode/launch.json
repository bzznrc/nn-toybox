{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Train",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.train",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--demo",
        "${input:activeDemo}",
        "--dataset",
        "${input:activeDataset}"
      ]
    },
    {
      "name": "View",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.view",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--demo",
        "${input:activeDemo}",
        "--dataset",
        "${input:activeDataset}"
      ]
    },
    {
      "name": "Capture",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.capture_demo",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "NN_TOYBOX_RENDER_VISIBLE": "0"
      },
      "args": [
        "--demo",
        "${input:activeDemo}",
        "--dataset",
        "${input:activeDataset}"
      ]
    }
  ],
  "inputs": [
    {
      "id": "activeDemo",
      "type": "pickString",
      "description": "Demo",
      "default": "grad",
      "options": [
        "grad",
        "embed",
        "autoencode",
        "diffuse"
      ]
    },
    {
      "id": "activeDataset",
      "type": "pickString",
      "description": "Dataset",
      "default": "moons",
      "options": [
        "moons",
        "circles",
        "spirals",
        "xor",
        "blobs",
        "checkerboard",
        "tiny_semantics",
        "icons",
        "rings",
        "gaussian_mixtures"
      ]
    }
  ]
}
